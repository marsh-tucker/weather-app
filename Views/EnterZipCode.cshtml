<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Get Weather Home</title>
</head>
<body>
    <header>
        <h1>Weather App</h1>
    </header>
    <h2>Enter a zip code</h2>
    <p>To get the weather information, please enter a valid zip code.</p>
    <p>Example: 12345</p>
    <form action="/Weather/GetWeatherActionMethod" method="get">
        <label for="zipCode">Enter Zip Code:</label>
        <input type="text" id="zipCode" name="zipCode" required>
        <button type="submit">Get Weather</button>
    </form>
</body>
</html>